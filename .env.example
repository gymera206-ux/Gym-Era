# --- Square ----
# Get your credentials from: Square Dashboard -> Developer -> Applications
# Use sandbox credentials for local testing, production for live.

SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=L...
SQUARE_ENVIRONMENT=sandbox

# Optional: your deployed site URL (used for success/cancel redirect URLs).
# Defaults to the request's origin if not set.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# --- PayPal ----
# Get your Client ID from: https://developer.paypal.com/dashboard/
# Use Sandbox Client ID for testing, Live for production.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_ORDER_API=

# --- Meta Conversions API ---
# Get these from Meta Events Manager -> Settings
META_PIXEL_ID=your_pixel_id
META_CONVERSIONS_API_TOKEN=your_conversions_api_token
