# Stripe: create a Payment Link in Stripe Dashboard and paste it here.
# Your customers will be sent to Stripe Checkout when they click "Pay with Stripe".
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# PayPal: get your Client ID from https://developer.paypal.com/dashboard/
# Use Sandbox Client ID for testing, Live for production.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Optional: serverless API URL that creates a PayPal order (POST with { amount, currency } returns { orderID }).
# Required for the PayPal button to work. You can deploy a small Vercel/Netlify function for this.
NEXT_PUBLIC_PAYPAL_ORDER_API=
