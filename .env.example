# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get both keys from: Stripe Dashboard → Developers → API Keys
# Use "sk_live_..." / "pk_live_..." for production.
# Use "sk_test_..." / "pk_test_..." for local testing.

STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Optional: your deployed site URL (used for success/cancel redirect URLs).
# Defaults to the request's origin if not set.
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ─── PayPal ─────────────────────────────────────────────────────────────────────
# Get your Client ID from: https://developer.paypal.com/dashboard/
# Use Sandbox Client ID for testing, Live for production.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_ORDER_API=
